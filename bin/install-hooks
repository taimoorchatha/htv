#!/usr/bin/env bash
# bin/install-hooks — wire bin/review as git pre-commit + pre-push hooks.
# Safe to re-run: overwrites both hooks.
set -eu
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
mkdir -p "$ROOT/.git/hooks"

# Pre-commit: fast staged-size + syntax check.
cat > "$ROOT/.git/hooks/pre-commit" <<'SH'
#!/usr/bin/env bash
set -e
ROOT="$(git rev-parse --show-toplevel)"
exec "$ROOT/bin/review" --staged
SH
chmod +x "$ROOT/.git/hooks/pre-commit"

# Pre-push: full suite.
cat > "$ROOT/.git/hooks/pre-push" <<'SH'
#!/usr/bin/env bash
set -e
ROOT="$(git rev-parse --show-toplevel)"
exec "$ROOT/bin/review"
SH
chmod +x "$ROOT/.git/hooks/pre-push"

echo "installed: .git/hooks/pre-commit  (--staged)"
echo "installed: .git/hooks/pre-push    (full)"

# A global core.hooksPath (e.g. set by agent-config) would shadow these hooks.
# Override locally so htv always runs bin/review.
git -C "$ROOT" config --local core.hooksPath .git/hooks
echo "set:       local core.hooksPath = .git/hooks  (overrides any global)"
